<div class='{{CG_messages}}'>

  {{#if isNotSelectedChat}}
    <div class='{{CG_messages elem='no-selected-chat'}}'>
      Выберите чат, чтобы начать общение
    </div>
  {{else}}
    {{#if isLoading}}
      {{> loader }}
    {{else}}
      <div class='{{CG_messages elem='user-header'}}'>
        <div class='{{CG_messages elem='avatar'}}'>
          {{> avatar src=companion.avatar alt='avatar' size='small' }}
        </div>
        <div class='{{CG_messages elem='companion-name'}}'>
          {{companion.first_name}} {{companion.second_name}}
        </div>
        <div class='{{CG_messages elem='companion-contacts'}}'>
          <div>Контакты:</div>
          <div class='{{CG_messages elem='companion-email'}}'>
            email: {{companion.email}}
          </div>
          <div class='{{CG_messages elem='companion-phone'}}'>
            телефон: {{companion.phone}}
          </div>
        </div>
      </div>
    {{/if}}
    <div id={{messageGroupsId}} class='{{CG_messages elem='message-list'}}'>
        <!-- блок для массива компонентов "группа сообщений по дате" -->
    </div>
    <div class='{{CG_messages elem='new-message-wrapper'}}'>
<!--      {{> button id='btn-edit-profile' value='' withIcon='clip' variant='pseudo' className=(CG_messages elem='btn-clip') disabled=true }}-->
      {{> textarea id=textareaId placeholder='Сообщение' name='message'}}
      {{> button id='send-message-btn' value='' withIcon='send' variant='pseudo' className=(CG_messages elem='btn-send')}}
    </div>
  {{/if}}

</div>
